# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────────────────────
# Square
# ─────────────────────────────────────────────
# Square Developer Dashboard > Applications > 該当アプリ > Credentials から取得
SQUARE_ACCESS_TOKEN=EAAA...
# production または sandbox
SQUARE_ENVIRONMENT=production

# Square Webhook用（Vercelデプロイ後に設定）
# Webhook subscription を作成したら Signature Key を取得
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Webhookで設定したエンドポイントURL（署名検証に使用）
SQUARE_WEBHOOK_URL=https://your-domain.vercel.app/api/square/webhook

# ─────────────────────────────────────────────
# サイト設定
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Sentry（本番監視・ローカルでは未設定でOK）
# ─────────────────────────────────────────────
# サーバー側のエラー収集 DSN
SENTRY_DSN=
# クライアント（ブラウザ）側のエラー収集 DSN
NEXT_PUBLIC_SENTRY_DSN=
# ソースマップ自動アップロードを有効化したい場合のみ設定
SENTRY_ORG=
SENTRY_PROJECT=
